{
  "provider": "openai",
  "displayName": "OpenAI",
  "apiKey": "${OPENAI_API_KEY}",
  "baseURL": "https://api.openai.com/v1",
  "organization": "${OPENAI_ORG_ID}",
  "models": {
    "default": "gpt-4-turbo",
    "available": [
      "gpt-4-turbo",
      "gpt-4-turbo-preview",
      "gpt-4",
      "gpt-3.5-turbo",
      "gpt-3.5-turbo-16k"
    ],
    "fallback": ["gpt-3.5-turbo"]
  },
  "rateLimits": {
    "requestsPerMinute": 100,
    "tokensPerMinute": 90000,
    "maxTokens": 128000
  },
  "pricing": {
    "input": 10.0,
    "output": 30.0,
    "currency": "USD",
    "unit": "perMillion"
  },
  "features": {
    "streaming": true,
    "functionCalling": true,
    "vision": true,
    "systemMessages": true
  }
}
